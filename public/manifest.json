{
  "$schema": "https://json.schemastore.org/chrome-manifest",
  "manifest_version": 3,
  "name": "Chrome Extension Template",
  "version": "1.0",
  "description": "Chrome Extension template project (Manifest V3)",
  "permissions": [
    "clipboardWrite",
    "activeTab"
  ],
  "host_permissions": [
    "https://example.com/*"
  ],
  "background": {
    "service_worker": "backgrounds_background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://example.com/*"
      ],
      "js": [
        "content_scripts_main.js"
      ],
      "run_at": "document_end"
    }
  ],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "action": {
    "default_title": "Extension Template",
    "default_popup": "popup.html"
  }
}
