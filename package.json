{
  "name": "chrome-live-group-template",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "wxt build",
    "build:prod": "wxt build",
    "dev": "wxt --host 127.0.0.1 --port 3000",
    "dev:web": "react-router dev",
    "build:web": "react-router build",
    "start": "react-router-serve ./build/server/index.js",
    "lint": "eslint --no-error-on-unmatched-pattern \"app/**/*.{ts,tsx}\" \"entrypoints/**/*.{ts,tsx}\" \"src/**/*.ts\" \"src/**/*.tsx\"",
    "lint:fix": "eslint --no-error-on-unmatched-pattern \"app/**/*.{ts,tsx}\" \"entrypoints/**/*.{ts,tsx}\" \"src/**/*.ts\" \"src/**/*.tsx\" --fix",
    "typecheck": "react-router typegen && tsc",
    "test": "node src/content_scripts/tests/test-detection.mjs",
    "prepare": "wxt prepare"
  },
  "dependencies": {
    "@react-router/node": "^7.13.1",
    "@react-router/serve": "^7.13.1",
    "isbot": "^5.1.36",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router": "^7.13.1"
  },
  "devDependencies": {
    "@react-router/dev": "^7.13.1",
    "@shiron-dev/eslint-config": "^2.1.5",
    "@types/chrome": "^0.0.316",
    "@types/node": "^20.19.37",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@wxt-dev/module-react": "^1.1.0",
    "eslint": "^10.0.3",
    "eslint-plugin-format": "^1.5.0",
    "jsdom": "^28.1.0",
    "react-router-devtools": "^1.1.10",
    "typescript": "^5.9.3",
    "vite": "5.4.21",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^4.1.0",
    "wxt": "^0.20.5"
  },
  "pnpm": {
    "overrides": {
      "vite": "5.4.21"
    }
  }
}
